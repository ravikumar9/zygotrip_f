{
  "name": "zygotrip-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"django,next\" --prefix-colors \"yellow,cyan\" \"npm run dev:backend\" \"npm run dev:next\"",
    "dev:next": "next dev",
    "dev:backend": "python ../manage.py runserver 127.0.0.1:8000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {

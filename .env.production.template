# ============================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================
# Copy this to .env and fill in production values
# DO NOT COMMIT ACTUAL SECRETS TO VERSION CONTROL

# Django Core
DEBUG=false
DJANGO_SECRET_KEY=<your-production-secret-key>
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database (PostgreSQL in production)
DATABASE_URL=postgresql://user:password@db-host:5432/zygotrip_prod
DATABASE_HOST=db-host
DATABASE_PORT=5432
DATABASE_NAME=zygotrip_prod
DATABASE_USER=zygotrip_user
DATABASE_PASSWORD=<secure-password>

# Redis (for caching and Celery)
REDIS_HOST=redis-host
REDIS_PORT=6379
USE_REDIS_CACHE=true

# Celery
CELERY_BROKER_URL=redis://redis-host:6379/0
CELERY_RESULT_BACKEND=redis://redis-host:6379/2

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=<your-email>
EMAIL_HOST_PASSWORD=<app-password>

# Payment Gateway (Razorpay, Stripe, etc.)
PAYMENT_GATEWAY=razorpay
RAZORPAY_KEY_ID=<razorpay-key>
RAZORPAY_KEY_SECRET=<razorpay-secret>

# AWS S3 (for media/static files)
USE_S3=true
AWS_ACCESS_KEY_ID=<aws-access-key>
AWS_SECRET_ACCESS_KEY=<aws-secret-key>
AWS_STORAGE_BUCKET_NAME=zygotrip-prod
AWS_S3_REGION_NAME=ap-south-1

# Logging
LOG_LEVEL=INFO
SENTRY_DSN=<sentry-dsn-for-error-tracking>

# Business Configuration
BOOKING_COMMISSION_RATE=0.15
GST_RATE=0.18
PAYMENT_GATEWAY_FEE_RATE=0.02
REFUND_FREE_DEADLINE_HOURS=72
REFUND_PARTIAL_DEADLINE_HOURS=24
REFUND_PARTIAL_PERCENTAGE=0.50

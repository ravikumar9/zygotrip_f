# ═══════════════════════════════════════════════════════════════════════
# ZygoTrip OTA Platform — Environment Configuration
# Copy this file to .env and fill in production values
# ═══════════════════════════════════════════════════════════════════════

# ── Django Core ───────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-minimum-50-chars
DEBUG=false
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_DB=zygotrip_db
POSTGRES_USER=zygotrip_user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DB_CONN_MAX_AGE=60

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
USE_REDIS_CACHE=true

# ── Celery ────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Gunicorn ──────────────────────────────────────────────────────────
GUNICORN_WORKERS=5
GUNICORN_THREADS=4
GUNICORN_BIND=0.0.0.0:8000
GUNICORN_LOG_LEVEL=info

# ── Next.js Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://yourdomain.com

# ── Django Admin Superuser (auto-created on first deploy) ─────────────
DJANGO_SUPERUSER_EMAIL=admin@zygotrip.com
DJANGO_SUPERUSER_PASSWORD=CHANGE_THIS

# ── CORS ──────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Payment Gateways ─────────────────────────────────────────────────
# Cashfree
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=production
CASHFREE_WEBHOOK_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Paytm UPI
PAYTM_MERCHANT_ID=
PAYTM_MERCHANT_KEY=
PAYTM_ENV=production

# Payment URLs
PAYMENT_SUCCESS_URL=https://yourdomain.com/booking/confirmation
PAYMENT_CANCEL_URL=https://yourdomain.com/payment/cancelled

# ── SMS / OTP ────────────────────────────────────────────────────────
SMS_BACKEND=msg91
OTP_EXPIRY_MINUTES=5
MAX_OTP_PER_HOUR=5
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# ── Email (booking confirmations) ────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=notifications@zygotrip.com
EMAIL_HOST_PASSWORD=your-app-password

# ── SSL Certificates ─────────────────────────────────────────────────
SSL_CERT_PATH=/path/to/ssl/certs

# ── AWS S3 (media storage) ───────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=zygotrip-media
AWS_S3_REGION_NAME=ap-south-1

# ── Sentry (error tracking) ──────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
